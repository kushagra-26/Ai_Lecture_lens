# App
PORT=5000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
# LLM API — Gemini 2.0 Flash (free tier: 1500 req/day)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OpenAI (optional fallback, paid)
# OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

MONGO_URI=mongodb://mongo:27017/smartlecture

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Storage
STORAGE_LOCAL_PATH=./uploads
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-south-1

# AI microservices (FastAPI)
TRANSCRIBE_SERVICE_URL=http://python-ai:8000/transcribe
EXTRACT_SERVICE_URL=http://python-ai:8000/extract
QUIZ_SERVICE_URL=http://python-ai:8000/quiz
SUMMARIZE_SERVICE_URL=http://python-ai:8000/summarize
CLEAN_SERVICE_URL=http://python-ai:8000/clean

# Other
NODE_ENV=development
